generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("admin")
  emailVerified Boolean   @default(false)
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  accounts       Account[]
  verifications  Verification[]
  passwordResets PasswordReset[]
  projects       Project[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id              String    @id @default(cuid())
  userId          String?
  name            String
  domain          String
  language        String    @default("English")
  country         String    @default("United States")
  industry        String    @default("SaaS")
  description     String    @default("")
  status          String    @default("Active")
  reportsCount    Int       @default(0)
  geoScore        Int       @default(0)
  visibilityScore Int       @default(0)
  visibility      Int       @default(0)
  lastAnalysisAt  DateTime?
  lastScan        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  websiteScans WebsiteScan[]
  geoAnalyses  GeoAnalysis[]
  optimizationTasks OptimizationTask[]
  visibilityCampaigns VisibilityCampaign[]

  @@index([userId])
}

model WebsiteScan {
  id                String   @id @default(cuid())
  projectId         String
  url               String
  status            String
  title             String?
  description       String?
  h1Count           Int      @default(0)
  h2Count           Int      @default(0)
  internalLinkCount Int      @default(0)
  externalLinkCount Int      @default(0)
  schemaCount       Int      @default(0)
  schemaTypes       String[] @default([])
  robotsExists      Boolean  @default(false)
  sitemapExists     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  geoAnalysis GeoAnalysis?

  @@index([projectId])
}

model GeoAnalysis {
  id             String   @id @default(cuid())
  projectId      String
  scanId         String   @unique
  totalScore     Int
  entityScore    Int
  schemaScore    Int
  technicalScore Int
  contentScore   Int
  issues         Json
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scan    WebsiteScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([scanId])
}

model OptimizationTask {
  id             String   @id @default(cuid())
  projectId      String
  issueId        String
  title          String
  description    String   @default("")
  recommendation String   @default("")
  severity       String   @default("Medium")
  category       String   @default("")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@unique([projectId, issueId])
}

model VisibilityCampaign {
  id        String   @id @default(cuid())
  projectId String
  keyword   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompts VisibilityPrompt[]
  checks  VisibilityCheck[]

  @@index([projectId])
}

model VisibilityPrompt {
  id         String   @id @default(cuid())
  campaignId String
  prompt     String
  createdAt  DateTime @default(now())

  campaign VisibilityCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  checks   VisibilityCheck[]

  @@index([campaignId])
}

model VisibilityCheck {
  id             String   @id @default(cuid())
  campaignId     String
  promptId       String?
  provider       String
  prompt         String
  answer         String
  brandMentioned Boolean  @default(false)
  mentionPosition Int?
  sourceUrls     String[] @default([])
  score          Int      @default(0)
  createdAt      DateTime @default(now())

  campaign VisibilityCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  visibilityPrompt VisibilityPrompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([promptId])
}
