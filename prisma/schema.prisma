generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

enum GrowthEventType {
  SCAN
  ENTITY
  SIMULATION
  VISIBILITY
  OPTIMIZATION
}

enum GrowthTriggerType {
  MANUAL
  AUTO
  SCHEDULE
  API
}

enum CompetitorStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BenchmarkRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BenchmarkTargetType {
  OWN
  COMPETITOR
}

enum SimulationTargetType {
  OWN
  COMPETITOR
}

enum VisibilityEntityType {
  OWN
  COMPETITOR
  UNKNOWN
}

enum KnowledgeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum KnowledgeSourceType {
  USER_INPUT
  FILE_UPLOAD
  WEBSITE_CRAWL
  AI_GENERATED
}

enum KnowledgeProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          String   @default("admin")
  emailVerified Boolean  @default(false)
  image         String?
  passwordHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  accounts       Account[]
  verifications  Verification[]
  passwordResets PasswordReset[]
  projects       Project[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id              String    @id @default(cuid())
  userId          String?
  name            String
  domain          String
  language        String    @default("English")
  country         String    @default("United States")
  industry        String    @default("SaaS")
  description     String    @default("")
  status          String    @default("Active")
  reportsCount    Int       @default(0)
  geoScore        Int       @default(0)
  visibilityScore Int       @default(0)
  visibility      Int       @default(0)
  lastAnalysisAt  DateTime?
  lastScan        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  websiteScans        WebsiteScan[]
  geoAnalyses         GeoAnalysis[]
  optimizationTasks   OptimizationTask[]
  visibilityCampaigns VisibilityCampaign[]
  queryTemplates      QueryTemplate[]
  entityProfiles      EntityProfile[]
  geoBrainAnalyses    GeoBrainAnalysis[]
  geoCampaigns        GeoCampaign[]
  simulationTasks     SimulationTask[]
  growthSnapshots     GrowthSnapshot[]
  competitorProfiles  CompetitorProfile[]
  benchmarkRuns       BenchmarkRun[]
  knowledgeBase        CompanyKnowledgeBase?
  knowledgeSources     KnowledgeSource[]
  knowledgeDocuments   KnowledgeDocument[]
  productEntities      ProductEntity[]
  serviceEntities      ServiceEntity[]
  customerCases        CustomerCase[]
  technicalDocuments   TechnicalDocument[]
  knowledgeChunks      KnowledgeChunk[]

  @@index([userId])
}

model WebsiteScan {
  id                String   @id @default(cuid())
  projectId         String
  url               String
  status            String
  title             String?
  description       String?
  h1Count           Int      @default(0)
  h2Count           Int      @default(0)
  internalLinkCount Int      @default(0)
  externalLinkCount Int      @default(0)
  schemaCount       Int      @default(0)
  schemaTypes       String[] @default([])
  robotsExists      Boolean  @default(false)
  sitemapExists     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  geoAnalysis GeoAnalysis?

  @@index([projectId])
}

model GeoAnalysis {
  id             String   @id @default(cuid())
  projectId      String
  scanId         String   @unique
  totalScore     Int
  entityScore    Int
  schemaScore    Int
  technicalScore Int
  contentScore   Int
  issues         Json
  createdAt      DateTime @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scan    WebsiteScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([scanId])
}

model GeoBrainAnalysis {
  id              String   @id @default(cuid())
  projectId       String
  score           Int
  scoreDetails    Json     @default("{}")
  insights        Json
  problems        Json     @default("[]")
  recommendations Json
  aiSummary       String   @default("")
  provider        String
  model           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model OptimizationTask {
  id             String   @id @default(cuid())
  projectId      String
  issueId        String
  title          String
  description    String   @default("")
  recommendation String   @default("")
  severity       String   @default("Medium")
  category       String   @default("")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, issueId])
  @@index([projectId])
}

model QueryTemplate {
  id        String   @id @default(cuid())
  projectId String
  content   String
  category  String
  intent    String
  priority  String   @default("medium")
  status    String   @default("GENERATED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model EntityProfile {
  id          String   @id @default(cuid())
  projectId   String
  brandName   String
  industry    String
  region      String
  description String
  services    String[] @default([])
  products    String[] @default([])
  advantages  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attributes EntityAttribute[]

  @@index([projectId])
}

model EntityAttribute {
  id        String   @id @default(cuid())
  entityId  String
  key       String
  value     String
  source    String
  createdAt DateTime @default(now())

  entity EntityProfile @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

model CompanyKnowledgeBase {
  id                 String          @id @default(cuid())
  projectId          String          @unique
  status             KnowledgeStatus @default(DRAFT)
  version            Int             @default(1)
  completenessScore  Int?
  understandingScore Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources            KnowledgeSource[]
  documents          KnowledgeDocument[]
  products           ProductEntity[]
  services           ServiceEntity[]
  customerCases      CustomerCase[]
  technicalDocuments TechnicalDocument[]

  @@unique([id, projectId])
  @@index([projectId, status])
}

model KnowledgeSource {
  id              String              @id @default(cuid())
  projectId       String
  knowledgeBaseId String
  type            KnowledgeSourceType
  sourceName      String
  sourceKey       String
  url             String?
  checksum        String?
  confidence      Int?
  status          KnowledgeStatus     @default(DRAFT)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase      CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  document           KnowledgeDocument?
  products           ProductEntity[]
  services           ServiceEntity[]
  customerCases      CustomerCase[]
  technicalDocuments TechnicalDocument[]

  @@unique([id, projectId])
  @@unique([projectId, sourceKey])
  @@index([projectId, type, status])
  @@index([knowledgeBaseId])
}

model KnowledgeDocument {
  id                  String                    @id @default(cuid())
  projectId           String
  knowledgeBaseId     String
  sourceId            String                    @unique
  name                String
  mimeType            String
  size                Int
  processingStatus    KnowledgeProcessingStatus @default(PENDING)
  extractedTextStatus KnowledgeProcessingStatus @default(PENDING)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  source        KnowledgeSource      @relation(fields: [sourceId, projectId], references: [id, projectId], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@unique([id, projectId])
  @@unique([sourceId, projectId])
  @@index([projectId, processingStatus, createdAt])
  @@index([knowledgeBaseId])
}

model ProductEntity {
  id              String          @id @default(cuid())
  projectId       String
  knowledgeBaseId String
  sourceId        String
  name            String
  category        String
  description     String
  features        Json            @default("[]")
  applications    Json            @default("[]")
  targetCustomers Json            @default("[]")
  confidence      Int?
  status          KnowledgeStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  source        KnowledgeSource      @relation(fields: [sourceId, projectId], references: [id, projectId], onDelete: Cascade)

  @@index([projectId, status, updatedAt])
  @@index([knowledgeBaseId])
  @@index([sourceId])
}

model ServiceEntity {
  id              String          @id @default(cuid())
  projectId       String
  knowledgeBaseId String
  sourceId        String
  name            String
  description     String
  industries      Json            @default("[]")
  confidence      Int?
  status          KnowledgeStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  source        KnowledgeSource      @relation(fields: [sourceId, projectId], references: [id, projectId], onDelete: Cascade)

  @@index([projectId, status, updatedAt])
  @@index([knowledgeBaseId])
  @@index([sourceId])
}

model CustomerCase {
  id              String          @id @default(cuid())
  projectId       String
  knowledgeBaseId String
  sourceId        String
  customerName    String
  industry        String
  problem         String
  solution        String
  result          String
  metrics         Json            @default("{}")
  confidence      Int?
  status          KnowledgeStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  source        KnowledgeSource      @relation(fields: [sourceId, projectId], references: [id, projectId], onDelete: Cascade)

  @@index([projectId, status, updatedAt])
  @@index([knowledgeBaseId])
  @@index([sourceId])
}

model TechnicalDocument {
  id              String          @id @default(cuid())
  projectId       String
  knowledgeBaseId String
  sourceId        String
  title           String
  type            String
  summary         String
  technicalFields Json            @default("{}")
  confidence      Int?
  status          KnowledgeStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBase CompanyKnowledgeBase @relation(fields: [knowledgeBaseId, projectId], references: [id, projectId], onDelete: Cascade)
  source        KnowledgeSource      @relation(fields: [sourceId, projectId], references: [id, projectId], onDelete: Cascade)

  @@index([projectId, status, updatedAt])
  @@index([knowledgeBaseId])
  @@index([sourceId])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  projectId  String
  documentId String
  content    String
  hash       String
  order      Int
  tokenCount Int
  confidence Int?
  createdAt  DateTime @default(now())

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([documentId, order])
  @@index([projectId, hash])
  @@index([documentId])
}

model GeoCampaign {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  industry            String
  businessDescription String
  goal                String
  platforms           Json
  queryCount          Int      @default(0)
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queries         GeoQuery[]
  simulationTasks SimulationTask[]
  growthSnapshots GrowthSnapshot[]
  benchmarkRuns   BenchmarkRun[]

  @@index([projectId])
}

model GeoQuery {
  id         String   @id @default(cuid())
  campaignId String
  query      String
  category   String
  intent     String
  priority   String
  status     String   @default("MONITORING")
  createdAt  DateTime @default(now())

  campaign        GeoCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  simulationTasks SimulationTask[]

  @@index([campaignId])
}

model SimulationTask {
  id           String               @id @default(cuid())
  projectId    String
  campaignId   String?
  queryId      String?
  query        String
  provider     String
  targetType   SimulationTargetType @default(OWN)
  competitorId String?
  status       String               @default("PENDING")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign   GeoCampaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  geoQuery   GeoQuery?          @relation(fields: [queryId], references: [id], onDelete: SetNull)
  competitor CompetitorProfile? @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  result     SimulationResult?

  @@index([projectId])
  @@index([campaignId])
  @@index([queryId])
  @@index([competitorId])
}

model SimulationResult {
  id             String   @id @default(cuid())
  taskId         String   @unique
  probability    Int
  ranking        Int?
  confidence     Int
  entityScore    Int
  schemaScore    Int
  authorityScore Int
  citationScore  Int
  mentioned      Boolean  @default(false)
  reasons        Json
  missing        Json
  createdAt      DateTime @default(now())

  task            SimulationTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  growthSnapshots GrowthSnapshot[]

  @@index([taskId])
}

model GrowthSnapshot {
  id              String            @id @default(cuid())
  projectId       String
  campaignId      String?
  simulationId    String?
  eventType       GrowthEventType
  triggerType     GrowthTriggerType @default(AUTO)
  sourceId        String
  visibilityScore Int?
  entityScore     Int?
  schemaScore     Int?
  authorityScore  Int?
  citationScore   Int?
  overallScore    Int?
  metadata        Json              @default("{}")
  createdAt       DateTime          @default(now())

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign   GeoCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  simulation SimulationResult? @relation(fields: [simulationId], references: [id], onDelete: SetNull)

  @@unique([projectId, eventType, sourceId])
  @@index([projectId])
  @@index([campaignId])
  @@index([simulationId])
}

model VisibilityCampaign {
  id        String   @id @default(cuid())
  projectId String
  keyword   String
  createdAt DateTime @default(now())

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompts VisibilityPrompt[]
  checks  VisibilityCheck[]

  @@index([projectId])
}

model VisibilityPrompt {
  id         String   @id @default(cuid())
  campaignId String
  prompt     String
  createdAt  DateTime @default(now())

  campaign VisibilityCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  checks   VisibilityCheck[]

  @@index([campaignId])
}

model VisibilityCheck {
  id              String   @id @default(cuid())
  campaignId      String
  promptId        String?
  provider        String
  prompt          String
  answer          String
  brandMentioned  Boolean  @default(false)
  mentionPosition Int?
  sourceUrls      String[] @default([])
  score           Int      @default(0)
  createdAt       DateTime @default(now())

  campaign         VisibilityCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  visibilityPrompt VisibilityPrompt?    @relation(fields: [promptId], references: [id], onDelete: SetNull)
  mentions         VisibilityMention[]
  citations        VisibilityCitation[]

  @@index([campaignId])
  @@index([promptId])
}

model CompetitorProfile {
  id               String           @id @default(cuid())
  projectId        String
  name             String
  domain           String
  normalizedDomain String
  industry         String           @default("")
  region           String           @default("")
  status           CompetitorStatus @default(ACTIVE)
  metadata         Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots          CompetitorSnapshot[]
  benchmarkResults   BenchmarkResult[]
  simulationTasks    SimulationTask[]
  visibilityMentions VisibilityMention[]

  @@unique([projectId, normalizedDomain])
  @@index([projectId])
  @@index([status])
}

model CompetitorSnapshot {
  id              String   @id @default(cuid())
  competitorId    String
  overallScore    Int?
  visibilityScore Int?
  entityScore     Int?
  schemaScore     Int?
  authorityScore  Int?
  citationScore   Int?
  methodVersion   String
  sourceId        String
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  competitor CompetitorProfile @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, methodVersion, sourceId])
  @@index([competitorId, createdAt])
  @@index([competitorId, methodVersion, createdAt])
}

model BenchmarkRun {
  id            String             @id @default(cuid())
  projectId     String
  campaignId    String?
  runKey        String
  scopeHash     String
  provider      String
  methodVersion String
  windowStart   DateTime?
  windowEnd     DateTime?
  queryCount    Int                @default(0)
  status        BenchmarkRunStatus @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign GeoCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  results  BenchmarkResult[]

  @@unique([projectId, runKey])
  @@index([projectId, provider, createdAt])
  @@index([campaignId])
}

model BenchmarkResult {
  id              String              @id @default(cuid())
  benchmarkRunId  String
  targetType      BenchmarkTargetType
  targetKey       String
  competitorId    String?
  overallScore    Int?
  visibilityScore Int?
  entityScore     Int?
  schemaScore     Int?
  authorityScore  Int?
  citationScore   Int?
  simulationScore Int?
  difference      Int?
  ranking         Int?
  coverage        Int?
  confidence      Int?
  scoreBasis      String?
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now())

  benchmarkRun BenchmarkRun       @relation(fields: [benchmarkRunId], references: [id], onDelete: Cascade)
  competitor   CompetitorProfile? @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([benchmarkRunId, targetKey])
  @@index([benchmarkRunId, ranking])
  @@index([competitorId, createdAt])
}

model VisibilityMention {
  id             String               @id @default(cuid())
  checkId        String
  competitorId   String?
  entityType     VisibilityEntityType
  brandName      String
  normalizedName String
  position       Int?
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now())

  check      VisibilityCheck      @relation(fields: [checkId], references: [id], onDelete: Cascade)
  competitor CompetitorProfile?   @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  citations  VisibilityCitation[]

  @@unique([checkId, normalizedName])
  @@index([checkId, position])
  @@index([competitorId])
}

model VisibilityCitation {
  id        String   @id @default(cuid())
  checkId   String
  mentionId String?
  url       String
  domain    String
  position  Int?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  check   VisibilityCheck    @relation(fields: [checkId], references: [id], onDelete: Cascade)
  mention VisibilityMention? @relation(fields: [mentionId], references: [id], onDelete: SetNull)

  @@unique([checkId, url])
  @@index([checkId])
  @@index([mentionId])
  @@index([domain])
}
